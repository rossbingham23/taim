# ─────────────────────────────────────────────
# TAIM — Team AI Manager  |  Environment Config
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── PostgreSQL ───────────────────────────────
POSTGRES_DB=taim
POSTGRES_USER=taim
POSTGRES_PASSWORD=changeme_postgres

# ── Redis ────────────────────────────────────
REDIS_PASSWORD=changeme_redis

# ── Durable Task Scheduler ───────────────────
DURABLE_TASK_HUB=default
DURABLE_TASK_CONNECTION_STRING=Endpoint=http://durable-task-scheduler:8080;TaskHub=default;Authentication=None

# ── API ──────────────────────────────────────
API_PORT=5000
JWT_SECRET=changeme_jwt_secret_at_least_32_chars_long
JWT_ISSUER=taim
JWT_AUDIENCE=taim-web

# ── LLM Providers (optional — also configurable per-tenant in UI) ─────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
# Ollama — install natively (not Docker) then set these:
#   Linux/WSL2: curl -fsSL https://ollama.com/install.sh | sh && ollama serve
#   macOS:      brew install ollama && ollama serve
# Leave OLLAMA_BASE_URL blank to use the default (host.docker.internal:11434)
OLLAMA_BASE_URL=
# Model to use — must be pulled first: ollama pull qwen2.5:3b
OLLAMA_MODEL=qwen2.5:3b

# ── Search API ───────────────────────────────
# Brave Search API key — get a free key at https://brave.com/search/api/
BRAVE_API_KEY=

# ── Frontend ─────────────────────────────────
VITE_API_URL=http://localhost:5000
VITE_SIGNALR_URL=http://localhost:5000/hubs/agents
