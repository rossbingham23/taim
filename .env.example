# ─────────────────────────────────────────────
# TAIM — Team AI Manager  |  Environment Config
# Copy this file to .env and fill in your values
# ─────────────────────────────────────────────

# ── PostgreSQL ───────────────────────────────
POSTGRES_DB=taim
POSTGRES_USER=taim
POSTGRES_PASSWORD=changeme_postgres

# ── Redis ────────────────────────────────────
REDIS_PASSWORD=changeme_redis

# ── Durable Task Scheduler ───────────────────
DURABLE_TASK_HUB=default
DURABLE_TASK_CONNECTION_STRING=Endpoint=http://durable-task-scheduler:8080;TaskHub=default;Authentication=None

# ── API ──────────────────────────────────────
API_PORT=5000
JWT_SECRET=changeme_jwt_secret_at_least_32_chars_long
JWT_ISSUER=taim
JWT_AUDIENCE=taim-web

# ── LLM Providers (optional — also configurable per-tenant in UI) ─────────────
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
OLLAMA_BASE_URL=http://host.docker.internal:11434

# ── Frontend ─────────────────────────────────
VITE_API_URL=http://localhost:5000
VITE_SIGNALR_URL=http://localhost:5000/hubs/agents
